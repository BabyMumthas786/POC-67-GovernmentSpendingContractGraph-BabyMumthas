# ─── Government Spending Contract Graph — Environment Variables ───
# Copy this file to .env and fill in your actual API keys.

# ─── USAspending.gov ───
# Public API — no key required for basic endpoints, but set one here
# if you use an authenticated tier or want to track usage.
# Register at: https://api.usaspending.gov/
USASPENDING_API_KEY=your_usaspending_api_key_here

# ─── SAM.gov (System for Award Management) ───
# Required for vendor entity lookups via the SAM Entity Management API.
# Register at: https://sam.gov/content/entity-information
# Then request an API key from: https://open.gsa.gov/api/entity-api/
SAM_API_KEY=your_sam_gov_api_key_here

# ─── Frontend (Next.js) ───
# Backend API URL — defaults to http://127.0.0.1:8000 if not set.
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
